---
import LayoutMinimal from '../layouts/LayoutMinimal.astro';
---

<LayoutMinimal
  title="Recovery Pod Bristol | Coming Soon"
  description="Bristol's premium contrast therapy experience. Coming Soon."
  canonical="https://recoverypodbristol.com/waitlist">

    <main class="landing">
      <div class="landing__content">
        <!-- Logo Icon -->
        <div class="landing__icon">
          <i class="fa-solid fa-spa"></i>
        </div>

        <!-- Title -->
        <h1 class="landing__title">Recovery Pod</h1>
        <p class="landing__tagline">Heat. Cold. Heal.</p>

        <!-- Description -->
        <p class="landing__text">
          Bristol's premium contrast therapy experience. Swedish sauna and cold
          plunge sessions designed to boost recovery, reduce inflammation, and
          elevate your wellbeing. Coming soon.
        </p>

        <!-- Features -->
        <div class="landing__features">
          <div class="landing__feature">
            <i class="fa-solid fa-fire landing__feature-icon"></i>
            <span>Swedish Sauna</span>
          </div>
          <div class="landing__feature">
            <i class="fa-solid fa-snowflake landing__feature-icon"></i>
            <span>Cold Plunge</span>
          </div>
          <div class="landing__feature">
            <i class="fa-solid fa-heart-pulse landing__feature-icon"></i>
            <span>Recovery Tools</span>
          </div>
        </div>

        <!-- Email Signup -->
        <form
          class="landing__form"
          id="signup-form"
          name="waitlist"
          method="POST"
          data-netlify="true"
        >
          <input type="hidden" name="form-name" value="waitlist" />
          <input
            type="email"
            name="email"
            class="landing__input"
            placeholder="Enter your email"
            required
            aria-label="Email address"
          />
          <button type="submit" class="btn btn--secondary landing__submit">
            Join Waitlist
          </button>
        </form>
        <p class="landing__note">
          Be the first to know when we launch. No spam, ever.
        </p>

        <!-- Social Links -->
        <div class="landing__social">
          <a
            href="https://www.instagram.com/therecoverypodcontrasttherapy"
            class="landing__social-link"
            aria-label="Follow us on Instagram"
          >
            <i class="fa-brands fa-instagram"></i>
          </a>
        </div>
      </div>

      <!-- Footer -->
      <footer class="landing__footer">
        <p>&copy; 2025 Recovery Pod. All rights reserved.</p>
        <p>
          Calmly crafted by
          <a href="https://jamesiles.uk" target="_blank">James</a>
        </p>
      </footer>
    </main>

</LayoutMinimal>
