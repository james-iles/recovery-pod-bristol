---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Find Us | Recovery Pod Bristol"
  description="Find Recovery Pod Bristol at Valesco Fitness Collective, Brislington. Get directions, see how to arrive, and watch a walkthrough of the space."
  canonical="https://recoverypodbristol.com/find-us">

  <main class="page">

    <section class="hero hero--compact">
      <div class="container">
        <div class="hero__content hero__content--centered">
          <span class="hero__tagline">Location</span>
          <h1 class="hero__title">Find <span>Us</span></h1>
          <p class="hero__text">
            We&rsquo;re based in Brislington, Bristol. You can find the pod at the back of Valesco Fitness Collective, one of Bristol's largest functional fitness gyms.
            Everything you need to know about what to expect when you arrive can be found below.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="find-us__location">

          <div class="find-us__address">
            <h2 class="find-us__address-title">Our Address</h2>

            <div class="find-us__address-block">
              <div class="find-us__address-icon">
                <i class="fa-solid fa-location-dot"></i>
              </div>
              <div>
                <p class="find-us__address-line">Valesco Fitness Collective</p>
                <p class="find-us__address-line">Unit 6-7 Yelverton Road</p>
                <p class="find-us__address-line">Brislington</p>
                <p class="find-us__address-line">Bristol</p>
                <p class="find-us__address-line">BS4 5HP</p>
              </div>
            </div>

            <div class="find-us__address-block">
              <div class="find-us__address-icon">
                <i class="fa-solid fa-envelope"></i>
              </div>
              <div>
                <a href="mailto:hello@recoverypodbristol.com" class="find-us__address-link">
                  recoverypod@valesco.fitness
                </a>
              </div>
            </div>

            <div class="find-us__address-block">
              <div class="find-us__address-icon">
                <i class="fa-brands fa-instagram"></i>
              </div>
              <div>
                <a
                  href="https://www.instagram.com/therecoverypodcontrasttherapy"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="find-us__address-link">
                  @therecoverypodcontrasttherapy
                </a>
              </div>
            </div>

            <a href="/booking" class="btn btn--primary find-us__address-cta">
              Book a Session
            </a>
          </div>

          <div class="find-us__map">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2487.5283160600898!2d-2.548067702130126!3d51.43009075639759!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48718fa569d5430d%3A0xab0ea081f310cb67!2sValesco%20Fitness%20Collective%20-%20V3%20Brislington!5e0!3m2!1sen!2suk!4v1776252404213!5m2!1sen!2suk" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>

        </div>
      </div>
    </section>

    <section class="section section--ice">
      <div class="container">
        <div class="section__header">
          <h2 class="section__title">See the Space</h2>
          <p class="section__subtitle">A walkthrough of Recovery Pod before your first visit</p>
        </div>

        <div class="find-us__video">
          <!-- Replace this placeholder with a YouTube or Vimeo embed once the video is ready -->
          <div class="find-us__video-placeholder">
            <div class="find-us__video-play">
              <i class="fa-solid fa-play"></i>
            </div>
            <p>Video walkthrough coming soon</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section__header">
          <h2 class="section__title">When You Arrive</h2>
          <p class="section__subtitle">
            Everything you need to know from the car park to the plunge pool
          </p>
        </div>

        <div class="prep-tips">
          <div class="prep-tips__card">
            <div class="prep-tips__icon">
              <i class="fa-solid fa-square-parking"></i>
            </div>
            <h3 class="prep-tips__title">Parking</h3>
            <p class="prep-tips__text">
              Free on-site parking is available at Recovery Pod and Valesco Fitness Collective.
              Pull into the main car park and head up the steps for the main entrance to the gym's reception space.
            </p>
          </div>

          <div class="prep-tips__card">
            <div class="prep-tips__icon">
              <i class="fa-solid fa-door-open"></i>
            </div>
            <h3 class="prep-tips__title">Entering the Building</h3>
            <p class="prep-tips__text">
              Once through reception, toilets can be found to your right, and the Recovery Pod is located at the back of the main gym floor.
              The Pod is unmanned so make your way down, enter your code, and the space is all yours! There is space to change and keep your belongings
              in and outside the Recovery Pod.
            </p>
          </div>

          <div class="prep-tips__card">
            <div class="prep-tips__icon">
              <i class="fa-solid fa-mobile-screen"></i>
            </div>
            <h3 class="prep-tips__title">Your Booking Confirmation</h3>
            <p class="prep-tips__text">
              You will receive an email containing your access code for the smart door lock and any last-minute details
              24 hours before your booking. Check your inbox (and spam) and contact us as soon as possible if you haven&rsquo;t received it.
            </p>
          </div>

        </div>
      </div>
    </section>

    <section class="section section--ice">
      <div class="container">
        <div class="section__header">
          <h2 class="section__title">Ready to Book?</h2>
          <p class="section__subtitle">
            Reserve your session and we&rsquo;ll send everything you need to find us.
          </p>
          <a href="/booking" class="btn btn--primary btn--large">
            Book a Session
          </a>
        </div>
      </div>
    </section>

  </main>

</Layout>
