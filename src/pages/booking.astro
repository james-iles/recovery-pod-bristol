---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Book Your Session | Recovery Pod Bristol"
  description="Book your sauna and cold plunge contrast therapy session at Recovery Pod Bristol. Full access to Swedish sauna and ice bath facilities."
  canonical="https://recoverypodbristol.com/booking"
  >

    <main class="page">
      <section class="hero hero--compact">
        <div class="container">
          <div class="hero__content hero__content--centered">
            <span class="hero__tagline">Book Now</span>
            <h1 class="hero__title">Reserve Your <span>Session</span></h1>
            <p class="hero__text">
              Choose a time that works for you. Sessions include full access to
              our Swedish sauna and cold plunge facilities.
            </p>
          </div>
        </div>
      </section>

      <section class="section section--booking">
        <div class="booking-embed">
          <iframe
            src="https://app.acuityscheduling.com/schedule.php?owner=38359809&ref=embedded_csp"
            title="Schedule Appointment"
            width="100%"
            height="800"
            frameborder="0"
            allow="payment"
          ></iframe>
          <script
            src="https://embed.acuityscheduling.com/js/embed.js"
            type="text/javascript"
          ></script>
        </div>
      </section>
    </main>
</Layout>
