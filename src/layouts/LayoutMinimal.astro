---
const {
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogUrl = canonical,
  ogImage = "https://recoverypodbristol.com/assets/images/og-image.jpg",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Recovery Pod" />
    <meta name="theme-color" content="#66B9A3" />
    <meta name="keywords" content="sauna Bristol, cold plunge Bristol, contrast therapy Bristol, ice bath Bristol, Swedish sauna Bristol, recovery Bristol, wellness Bristol, cold water therapy" />
    <meta name="robots" content="noindex" />

    <link rel="canonical" href={canonical} />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/main.scss";
</style>
